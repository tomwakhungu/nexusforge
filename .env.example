# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# GitHub
GITHUB_APP_ID=xxxxx
GITHUB_PRIVATE_KEY=xxxxx
GITHUB_WEBHOOK_SECRET=xxxxx
NEXT_PUBLIC_GITHUB_APP_INSTALLATION_ID=xxxxx

# Sigstore
SIGSTORE_REKOR_URL=https://rekor.sigstore.dev
SIGSTORE_FULCIO_URL=https://fulcio.sigstore.dev
SIGSTORE_OIDC_ISSUER=https://oauth2.googleapis.com

# Auth
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# API
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# Features
NEXT_PUBLIC_ENABLE_AI_COPILOT=true
NEXT_PUBLIC_ENABLE_THREAT_INTEL=false

# Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=xxxxx
